node_modules/

# ─── Build output ────────────────────────────────────────────────────────────
dist/
dist-ssr/
*.local

# ─── Rust / Tauri ────────────────────────────────────────────────────────────
src-tauri/target/
src-tauri/gen/

# ─── Large runtime assets (NOT committed — run `npm run fetch-assets`) ────────
